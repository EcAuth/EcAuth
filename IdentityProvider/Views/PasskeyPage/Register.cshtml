@{
    ViewData["Title"] = "パスキーを登録";
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>パスキーを登録 — EcAuth</title>
    <style>
        :root { --p:#1a56db; --pd:#1240a8; --bg:#f9fafb; --card:#fff; --tx:#1f2937; --muted:#6b7280; --bd:#e5e7eb; --ok:#059669; }
        * { box-sizing: border-box; }
        body { margin:0; font-family: system-ui, "Noto Sans JP", sans-serif; background: var(--bg); color: var(--tx);
               min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1.5rem; }
        .card { background: var(--card); border:1px solid var(--bd); border-radius:12px; max-width:440px; width:100%;
                padding:2rem; text-align:center; }
        h1 { font-size:1.4rem; margin:0 0 .5rem; }
        p.lead { color: var(--muted); line-height:1.7; margin:0 0 1.5rem; }
        button { width:100%; padding:.85rem 1.5rem; font-size:1rem; font-weight:600; border:none; border-radius:8px;
                 background: var(--p); color:#fff; cursor:pointer; }
        button:hover { background: var(--pd); }
        button:disabled { opacity:.55; cursor:not-allowed; }
        .status { margin-top:1rem; padding:.85rem 1rem; border-radius:8px; font-size:.92rem; line-height:1.6; display:none; }
        .status.show { display:block; }
        .status.err { background:rgba(220,38,38,.1); color:#dc2626; border:1px solid rgba(220,38,38,.3); }
        .status.info { background:rgba(26,86,219,.08); color:var(--p); border:1px solid rgba(26,86,219,.25); }
        .status.ok { background:rgba(5,150,105,.12); color:var(--ok); border:1px solid rgba(5,150,105,.3); }
    </style>
</head>
<body>
    <div class="card">
        <h1>パスキーを登録</h1>
        <p class="lead">EcAuth ではパスワードの代わりにパスキー（指紋・顔認証・PIN 等）でログインします。この端末にパスキーを登録してください。</p>
        <button type="button" id="reg-btn">🔑 パスキーを登録する</button>
        <div class="status" id="status" role="status" aria-live="polite"></div>
    </div>

    <script>
    (function () {
        'use strict';
        var params = new URLSearchParams(window.location.search);
        // 登録トークンは URL フラグメント（#token=…）で受け取る。フラグメントはサーバへ
        // 送信されないため、アクセスログ / Azure Monitor / Referer にトークンが残らない。
        var hashParams = new URLSearchParams((window.location.hash || '').replace(/^#/, ''));
        var registrationToken = hashParams.get('token');
        var clientId = params.get('client_id');
        var email = params.get('email');
        var rpId = window.location.hostname;
        var mypageUrl = '@(ViewData["FrontendBaseUrl"])/mypage/';

        var btn = document.getElementById('reg-btn');
        var statusEl = document.getElementById('status');
        function setStatus(type, text) { statusEl.className = 'status show ' + type; statusEl.textContent = text; }

        function b64uEnc(buf) {
            var bytes = new Uint8Array(buf), bin = '';
            for (var i = 0; i < bytes.byteLength; i++) bin += String.fromCharCode(bytes[i]);
            return btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }
        function b64uDec(s) {
            var b = s.replace(/-/g, '+').replace(/_/g, '/');
            var pad = '='.repeat((4 - b.length % 4) % 4);
            var bin = atob(b + pad), out = new Uint8Array(bin.length);
            for (var i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i);
            return out.buffer;
        }

        if (!registrationToken || !clientId) {
            btn.disabled = true;
            setStatus('err', 'リンクが正しくありません。申込確認メールからやり直してください。');
            return;
        }
        if (!window.PublicKeyCredential) {
            btn.disabled = true;
            setStatus('err', 'この端末・ブラウザはパスキーに対応していません。');
            return;
        }

        btn.addEventListener('click', async function () {
            btn.disabled = true;
            setStatus('info', '登録中…');
            try {
                var optRes = await fetch('/v1/b2b/passkey/register/options', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        client_id: clientId,
                        registration_token: registrationToken,
                        rp_id: rpId,
                        display_name: email || undefined
                    })
                });
                if (!optRes.ok) { var e1 = await optRes.json().catch(function(){return {};}); throw new Error(e1.error_description || 'オプション取得に失敗しました。'); }
                var optData = await optRes.json();
                var sessionId = optData.session_id;
                var o = optData.options;

                var publicKey = {
                    challenge: b64uDec(o.challenge),
                    rp: { id: o.rp.id, name: o.rp.name },
                    user: { id: b64uDec(o.user.id), name: o.user.name, displayName: o.user.displayName },
                    pubKeyCredParams: o.pubKeyCredParams.map(function (p) { return { type: p.type, alg: p.alg }; }),
                    timeout: o.timeout,
                    attestation: o.attestation,
                    authenticatorSelection: o.authenticatorSelection,
                    excludeCredentials: (o.excludeCredentials || []).map(function (c) {
                        return { type: c.type, id: b64uDec(c.id), transports: c.transports };
                    })
                };

                var cred = await navigator.credentials.create({ publicKey: publicKey });

                var verifyRes = await fetch('/v1/b2b/passkey/register/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        client_id: clientId,
                        registration_token: registrationToken,
                        session_id: sessionId,
                        response: {
                            id: cred.id,
                            rawId: b64uEnc(cred.rawId),
                            response: {
                                attestationObject: b64uEnc(cred.response.attestationObject),
                                clientDataJSON: b64uEnc(cred.response.clientDataJSON),
                                transports: cred.response.getTransports ? cred.response.getTransports() : []
                            },
                            type: cred.type,
                            clientExtensionResults: cred.getClientExtensionResults ? cred.getClientExtensionResults() : {}
                        }
                    })
                });
                if (!verifyRes.ok) { var e2 = await verifyRes.json().catch(function(){return {};}); throw new Error(e2.error_description || '登録に失敗しました。'); }

                setStatus('ok', 'パスキーを登録しました。マイページに移動します…');
                setTimeout(function () { window.location.href = mypageUrl; }, 1200);
            } catch (err) {
                btn.disabled = false;
                var msg = (err && err.name === 'NotAllowedError')
                    ? 'パスキー登録がキャンセルされました。'
                    : (err && err.message) || '登録に失敗しました。';
                setStatus('err', msg);
            }
        });
    })();
    </script>
</body>
</html>
