@{
    ViewData["Title"] = "パスキーで認証";
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>パスキーで認証 — EcAuth</title>
    <style>
        :root { --p:#1a56db; --pd:#1240a8; --bg:#f9fafb; --card:#fff; --tx:#1f2937; --muted:#6b7280; --bd:#e5e7eb; }
        * { box-sizing: border-box; }
        body { margin:0; font-family: system-ui, "Noto Sans JP", sans-serif; background: var(--bg); color: var(--tx);
               min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1.5rem; }
        .card { background: var(--card); border:1px solid var(--bd); border-radius:12px; max-width:440px; width:100%;
                padding:2rem; text-align:center; }
        h1 { font-size:1.4rem; margin:0 0 .5rem; }
        p.lead { color: var(--muted); line-height:1.7; margin:0 0 1.5rem; }
        button { width:100%; padding:.85rem 1.5rem; font-size:1rem; font-weight:600; border:none; border-radius:8px;
                 background: var(--p); color:#fff; cursor:pointer; }
        button:hover { background: var(--pd); }
        button:disabled { opacity:.55; cursor:not-allowed; }
        .status { margin-top:1rem; padding:.85rem 1rem; border-radius:8px; font-size:.92rem; line-height:1.6; display:none; }
        .status.show { display:block; }
        .status.err { background:rgba(220,38,38,.1); color:#dc2626; border:1px solid rgba(220,38,38,.3); }
        .status.info { background:rgba(26,86,219,.08); color:var(--p); border:1px solid rgba(26,86,219,.25); }
        .foot { margin-top:1.25rem; font-size:.85rem; }
        .foot a { color: var(--muted); }
    </style>
</head>
<body>
    <div class="card">
        <h1>パスキーでログイン</h1>
        <p class="lead">登録済みのパスキー（指紋・顔認証・PIN 等）で認証します。</p>
        <button type="button" id="auth-btn">🔑 パスキーで認証する</button>
        <div class="status" id="status" role="status" aria-live="polite"></div>
        <p class="foot"><a href="https://ec-auth.io/signin/">パスキーが使えない方はこちら</a></p>
    </div>

    <script>
    (function () {
        'use strict';
        var params = new URLSearchParams(window.location.search);
        var clientId = params.get('client_id');
        var redirectUri = params.get('redirect_uri');
        var codeChallenge = params.get('code_challenge');
        var codeChallengeMethod = params.get('code_challenge_method') || 'S256';
        var state = params.get('state');
        var rpId = window.location.hostname;

        var btn = document.getElementById('auth-btn');
        var statusEl = document.getElementById('status');

        function setStatus(type, text) { statusEl.className = 'status show ' + type; statusEl.textContent = text; }

        function b64uEnc(buf) {
            var bytes = new Uint8Array(buf), bin = '';
            for (var i = 0; i < bytes.byteLength; i++) bin += String.fromCharCode(bytes[i]);
            return btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }
        function b64uDec(s) {
            var b = s.replace(/-/g, '+').replace(/_/g, '/');
            var pad = '='.repeat((4 - b.length % 4) % 4);
            var bin = atob(b + pad), out = new Uint8Array(bin.length);
            for (var i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i);
            return out.buffer;
        }

        if (!clientId || !redirectUri) {
            btn.disabled = true;
            setStatus('err', 'リクエストが不正です。マイページから再度ログインしてください。');
            return;
        }
        if (!window.PublicKeyCredential) {
            btn.disabled = true;
            setStatus('err', 'この端末・ブラウザはパスキーに対応していません。');
            return;
        }

        btn.addEventListener('click', async function () {
            btn.disabled = true;
            setStatus('info', '認証中…');
            try {
                var optRes = await fetch('/v1/b2b/passkey/authenticate/options', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ client_id: clientId, rp_id: rpId })
                });
                if (!optRes.ok) { var e1 = await optRes.json().catch(function(){return {};}); throw new Error(e1.error_description || 'オプション取得に失敗しました。'); }
                var optData = await optRes.json();
                var sessionId = optData.session_id;
                var o = optData.options;

                var publicKey = {
                    challenge: b64uDec(o.challenge),
                    rpId: o.rpId,
                    allowCredentials: (o.allowCredentials || []).map(function (c) {
                        return { type: c.type, id: b64uDec(c.id), transports: c.transports };
                    }),
                    userVerification: o.userVerification,
                    timeout: o.timeout
                };

                var cred = await navigator.credentials.get({ publicKey: publicKey });

                var verifyRes = await fetch('/v1/b2b/passkey/authenticate/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        client_id: clientId,
                        session_id: sessionId,
                        redirect_uri: redirectUri,
                        state: state || undefined,
                        code_challenge: codeChallenge || undefined,
                        code_challenge_method: codeChallenge ? codeChallengeMethod : undefined,
                        response: {
                            id: cred.id,
                            rawId: b64uEnc(cred.rawId),
                            response: {
                                authenticatorData: b64uEnc(cred.response.authenticatorData),
                                clientDataJSON: b64uEnc(cred.response.clientDataJSON),
                                signature: b64uEnc(cred.response.signature),
                                userHandle: cred.response.userHandle ? b64uEnc(cred.response.userHandle) : null
                            },
                            type: cred.type,
                            clientExtensionResults: cred.getClientExtensionResults ? cred.getClientExtensionResults() : {}
                        }
                    })
                });
                if (!verifyRes.ok) { var e2 = await verifyRes.json().catch(function(){return {};}); throw new Error(e2.error_description || '認証に失敗しました。'); }
                var vData = await verifyRes.json();
                if (vData.redirect_url) {
                    setStatus('info', '認証に成功しました。移動しています…');
                    // redirect_url はサーバが登録済み redirect_uri から生成した信頼できる値
                    window.location.href = vData.redirect_url;
                } else {
                    throw new Error('リダイレクト先を取得できませんでした。');
                }
            } catch (err) {
                btn.disabled = false;
                var msg = (err && err.name === 'NotAllowedError')
                    ? 'パスキー認証がキャンセルされました。'
                    : (err && err.message) || '認証に失敗しました。';
                setStatus('err', msg);
            }
        });
    })();
    </script>
</body>
</html>
